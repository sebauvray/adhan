# === Adhan Home ===
# Docker / infrastructure config only.
# All app settings (mosque, OwnTone, HomePods) are managed via the web UI: http://localhost:8080

# Timezone
TZ=Europe/Paris

# Web UI port (change if 8080 is already in use)
WEB_PORT=8080

# Container names (change if they conflict with existing containers)
CONTAINER_NAME_WEB=adhan-web
CONTAINER_NAME_ADHAN=adhan-home
CONTAINER_NAME_OWNTONE=owntone

# OwnTone — host user UID/GID (default: 1000, works on most Linux installs)
# Change only if your audio files belong to a different user
# Run `id -u` and `id -g` in a terminal to find yours
CURRENT_UID=1000
CURRENT_GID=1000

# Cookie security
# false → HTTP only (LAN/dev). true → HTTPS only (required if exposed via a TLS proxy).
COOKIE_SECURE=false

# Fetching mode (build-time)
# false → Mawaqit HTTP  (lightweight, recommended)
# true  → Mawaqit Selenium (requires Firefox)
AUTONOMOUS=false

# Build versions (optional)
DEBIAN_VERSION=bookworm
GECKODRIVER_VERSION=v0.34.0

# External audio images — pinned on purpose (no `latest`, so updates are
# deliberate). To upgrade: bump the tag, run `make up`, test, then commit.
MA_IMAGE_TAG=2.9.1
OWNTONE_IMAGE_TAG=29.2

# Native OwnTone install (macOS only)
# true  → `make up` builds & runs OwnTone directly on the Mac (deps + source build
#         + launchd service auto-starting at login). REQUIRED for HomePods: a
#         containerized AirPlay sender can't reach them from the Docker VM IP.
# false → no native install (use only if you run OwnTone/another sender yourself).
# Requires Homebrew. Optional: OWNTONE_MEDIA_DIR overrides the library dir
# (default: ~/Music/OwnTone — your personal music + adhan/alert files live here).
OWNTONE_NATIVE=true
#OWNTONE_MEDIA_DIR=
