# === Adhan Home ===
# Docker / infrastructure config only.
# All app settings (mosque, OwnTone, HomePods) are managed via the web UI: http://localhost:8080

# Timezone
TZ=Europe/Paris

# Web UI port
WEB_PORT=8080

# Container name
CONTAINER_NAME_ADHAN=adhan-home

# OwnTone — host user UID/GID (default: 1000, works on most Linux installs)
# Change only if your audio files belong to a different user
# Run `id -u` and `id -g` in a terminal to find yours
CURRENT_UID=1000
CURRENT_GID=1000

# Fetching mode (build-time)
# false → Mawaqit HTTP  (lightweight, recommended)
# true  → Mawaqit Selenium (requires Firefox)
AUTONOMOUS=false

# Build versions (optional)
DEBIAN_VERSION=bookworm
GECKODRIVER_VERSION=v0.34.0
